{
  "outputDirectory": "public",
  "functions": {
    "api/handler.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/plan", "destination": "/api/handler" },
    { "source": "/api/health", "destination": "/api/handler" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
